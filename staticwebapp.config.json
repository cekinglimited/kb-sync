{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/sharepoint_sync/*.{json,txt}",
      "/*.css",
      "/*.js",
      "/favicon.ico",
      "/assets/*"
    ]
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html"
    }
  },
  "mimeTypes": {
    ".json": "application/json"
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  }
}
